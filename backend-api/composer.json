{
  "name": "network-packet-analyzer/backend-api",
  "description": "Network Packet Analyzer Backend API - Built with Laravel",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0",
    "laravel/tinker": "^2.8",
    "laravel/sanctum": "^3.0",
    "predis/predis": "^2.2",
    "guzzlehttp/guzzle": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "laravel/pint": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php artisan optimize:clear"
    ]
  }
}
