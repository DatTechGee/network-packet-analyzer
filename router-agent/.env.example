DEBUG=True
LOG_LEVEL=INFO

# API Configuration
BACKEND_URL=http://localhost:8000/api
ROUTER_AGENT_PORT=5000
ROUTER_AGENT_KEY=your_secure_key_here

# Packet Capture
INTERFACE=eth0
PACKET_BUFFER_SIZE=10000
ANALYSIS_INTERVAL=30

# Threat Detection
ENABLE_IDS=True
ENABLE_DPI=True
THREAT_DB_PATH=/var/lib/packet-analyzer/threats

# Content Filtering
ENABLE_CONTENT_FILTER=True
BLOCK_ADULT_CONTENT=False
BLOCK_GAMBLING=False

# Database
DB_PATH=/var/lib/packet-analyzer/db
